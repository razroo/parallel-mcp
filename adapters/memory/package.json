{
  "name": "@razroo/parallel-mcp-memory",
  "version": "0.1.1",
  "description": "Minimal in-memory AsyncParallelMcpStore reference adapter for @razroo/parallel-mcp",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/razroo/parallel-mcp.git",
    "directory": "adapters/memory"
  },
  "homepage": "https://github.com/razroo/parallel-mcp/tree/main/adapters/memory#readme",
  "bugs": {
    "url": "https://github.com/razroo/parallel-mcp/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "node ./scripts/prepack.mjs",
    "postpublish": "node ./scripts/postpack.mjs",
    "prepublishOnly": "npm run check && npm test && npm run build",
    "pack:check": "npm run prepublishOnly && npm pack --dry-run; node ./scripts/postpack.mjs"
  },
  "keywords": [
    "mcp",
    "parallel",
    "orchestration",
    "in-memory",
    "reference",
    "adapter"
  ],
  "peerDependencies": {
    "@razroo/parallel-mcp": ">=0.3.0 <1.0.0"
  },
  "dependencies": {
    "@razroo/parallel-mcp": "file:../.."
  },
  "devDependencies": {
    "@razroo/parallel-mcp-testkit": "file:../../testkit",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
