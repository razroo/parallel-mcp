{
  "name": "@razroo/parallel-mcp",
  "version": "0.1.0",
  "description": "Durable orchestration core for parallel MCP workloads",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/razroo/parallel-mcp.git"
  },
  "homepage": "https://github.com/razroo/parallel-mcp#readme",
  "bugs": {
    "url": "https://github.com/razroo/parallel-mcp/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run check && npm test && npm run build",
    "pack:check": "npm run prepublishOnly && npm pack --dry-run"
  },
  "keywords": [
    "mcp",
    "parallel",
    "orchestration",
    "workflow",
    "sqlite"
  ],
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
