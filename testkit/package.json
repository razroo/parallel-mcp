{
  "name": "@razroo/parallel-mcp-testkit",
  "version": "0.2.0",
  "description": "Conformance test suite for alternative @razroo/parallel-mcp orchestrator/store implementations",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/razroo/parallel-mcp.git",
    "directory": "testkit"
  },
  "homepage": "https://github.com/razroo/parallel-mcp/tree/main/testkit#readme",
  "bugs": {
    "url": "https://github.com/razroo/parallel-mcp/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "node ./scripts/prepack.mjs",
    "postpack": "node ./scripts/postpack.mjs",
    "prepublishOnly": "npm run check && npm test && npm run build",
    "pack:check": "npm run prepublishOnly && npm pack --dry-run"
  },
  "keywords": [
    "mcp",
    "parallel",
    "orchestration",
    "testkit",
    "conformance"
  ],
  "peerDependencies": {
    "@razroo/parallel-mcp": ">=0.2.0 <1.0.0",
    "vitest": ">=1.0.0 <5.0.0"
  },
  "dependencies": {
    "@razroo/parallel-mcp": "file:.."
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
